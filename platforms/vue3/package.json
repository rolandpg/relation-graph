{
  "name": "@relation-graph/vue3",
  "version": "3.0.12",
  "description": "Vue relationship graph component for visualizing and editing knowledge graphs, org charts, and equity structures. Supports Vue 2 & Vue 3, force-directed layouts, tree layouts, and interactive graph editing.",
  "main": "./relation-graph.js",
  "module": "./relation-graph.mjs",
  "unpkg": "./relation-graph.umd.js",
  "types": "./types/packages/platforms/vue3/src/index.d.ts",
  "style": "./style.css",
  "exports": {
    ".": {
      "types": "./types/packages/platforms/vue3/src/index.d.ts",
      "node": "./relation-graph.ssr.mjs",
      "import": "./relation-graph.mjs",
      "require": "./relation-graph.js",
      "default": "./relation-graph.mjs"
    },
    "./style.css": "./style.css"
  },
  "author": "WanLian <seeksdream@qq.com>",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relation-graph/relation-graph.git"
  },
  "homepage": "https://relation-graph.com",
  "keywords": [
    "relation-graph vue version",
    "vue relationship graph",
    "vue knowledge graph",
    "vue graph editor",
    "vue graph visualization",
    "vue network topology",
    "vue flowchart",
    "vue force layout",
    "vue dag",
    "vue uml",
    "vue er diagram",
    "vue component",
    "vue 关系图谱",
    "vue 知识图谱",
    "vue 图谱编辑器",
    "vue 流程图",
    "vue 网络拓扑",
    "vue 数据可视化"
  ],
  "bugs": {
    "url": "https://github.com/relation-graph/relation-graph/issues"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "*",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-eslint-plugin": "^2.3.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-standard": "^5.0.0",
    "eslint-plugin-vue": "^8.7.1",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4",
    "vue-eslint-parser": "^9.3.1",
    "yaml-eslint-parser": "^1.0.1"
  },
  "directories": {
    "doc": "doc",
    "example": "examples"
  }
}
