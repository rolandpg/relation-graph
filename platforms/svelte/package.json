{
  "name": "@relation-graph/svelte",
  "version": "3.0.12",
  "description": "Svelte relationship graph component for visualizing knowledge graphs, network topologies, and complex hierarchies. Lightweight and powerful, supporting force layouts, tree layouts, and interactive editing in Svelte projects.",
  "main": "./relation-graph.cjs",
  "module": "./relation-graph.mjs",
  "svelte": "./relation-graph.mjs",
  "types": "./types/packages/platforms/svelte/src/index.d.ts",
  "style": "./style.css",
  "exports": {
    ".": {
      "types": "./types/packages/platforms/svelte/src/index.d.ts",
      "import": "./relation-graph.mjs",
      "require": "./relation-graph.cjs"
    },
    "./style.css": "./style.css"
  },
  "author": "WanLian <seeksdream@qq.com>",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relation-graph/relation-graph.git"
  },
  "homepage": "https://relation-graph.com",
  "keywords": [
    "relation-graph react version",
    "react relationship graph",
    "react knowledge graph",
    "react graph editor",
    "react graph visualization",
    "react network topology",
    "react flowchart",
    "react force layout",
    "react dag",
    "react uml",
    "react er diagram",
    "react component",
    "react 关系图谱",
    "react 知识图谱",
    "react 图谱编辑器",
    "react 流程图",
    "react 网络拓扑",
    "react 数据可视化"
  ],
  "bugs": {
    "url": "https://github.com/relation-graph/relation-graph/issues"
  },
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "svelte": "^4.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "*",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-eslint-plugin": "^2.3.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-standard": "^5.0.0",
    "eslint-plugin-vue": "^8.7.1",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4",
