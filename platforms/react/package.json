{
  "name": "@relation-graph/react",
  "version": "3.0.13",
  "description": "React relationship graph component for visualizing and editing knowledge graphs, DAGs, and flowcharts. Features force-directed layout, tree layout, and advanced graph editing capabilities for React applications.",
  "main": "./relation-graph.js",
  "module": "./relation-graph.mjs",
  "unpkg": "./relation-graph.umd.js",
  "types": "./types/packages/platforms/react/src/index.d.ts",
  "style": "./style.css",
  "exports": {
    ".": {
      "types": "./types/packages/platforms/react/src/index.d.ts",
      "node": "./relation-graph.ssr.mjs",
      "import": "./relation-graph.mjs",
      "require": "./relation-graph.js",
      "default": "./relation-graph.mjs"
    },
    "./style.css": "./style.css"
  },
  "author": "WanLian <seeksdream@qq.com>",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relation-graph/relation-graph.git"
  },
  "homepage": "http://relation-graph.com",
  "keywords": [
    "relation-graph react version",
    "react relationship graph",
    "react knowledge graph",
    "react graph editor",
    "react graph visualization",
    "react network topology",
    "react flowchart",
    "react force layout",
    "react dag",
    "react uml",
    "react er diagram",
    "react component",
    "react 关系图谱",
    "react 知识图谱",
    "react 图谱编辑器",
    "react 流程图",
    "react 网络拓扑",
    "react relation data visualization"
  ],
  "bugs": {
    "url": "https://github.com/relation-graph/relation-graph/issues"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "*",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-eslint-plugin": "^2.3.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-standard": "^5.0.0",
    "eslint-plugin-vue": "^8.7.1",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4",
    "vue-eslint-parser": "^9.3.1",
    "yaml-eslint-parser": "^1.0.1"
